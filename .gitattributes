# Cross-platform line ending normalization.
# Ensures consistent LF endings in the repository regardless of the OS
# where git operations are performed, eliminating CRLF warnings on Windows.

* text=auto
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.sh   text eol=lf
*.ps1  text eol=crlf
*.env  text eol=lf
*.example text eol=lf

# Binary files — never normalize
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary

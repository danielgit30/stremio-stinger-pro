# Port to run the server on (defaults to 7000)
PORT=7000

# TMDB API Key for movie metadata and fallback verification (optional but recommended)
TMDB_API_KEY=your_tmdb_api_key_here

# Redis URL for caching (optional, falls back to in-memory cache if not provided)
# Example: redis://localhost:6379
REDIS_URL=

# Enable or disable verbose console logging (defaults to true)
# Set to 'false' to disable in production
ENABLE_LOGGING=true

# Node.js environment (set to 'production' in all deployed environments)
# When set to 'production', the logger emits structured JSON instead of plain text,
# which is required for Cloud Run, Render, Railway, and other PaaS log aggregators.
NODE_ENV=development
